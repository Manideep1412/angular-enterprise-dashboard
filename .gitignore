# ── .NET ──────────────────────────────────────────────────────────
bin/
obj/
*.user
*.suo
.vs/
*.nupkg

# !! SECRETS — never commit real credentials
appsettings.json
appsettings.Development.json
appsettings.Production.json
# Commit appsettings.example.json instead

# SQLite database files (auto-generated on first run)
*.db
*.db-shm
*.db-wal

# Log files
logs/
*.log

# ── Angular ───────────────────────────────────────────────────────
node_modules/
dist/
.angular/cache/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── Test output ───────────────────────────────────────────────────
# Angular/Karma coverage reports
frontend/coverage/
frontend/.nyc_output/
frontend/out-tsc/

# .NET test results and coverage
backend/TestResults/
backend/**/*.coverage
backend/**/coverage.cobertura.xml
backend/**/lcov.info

# Playwright / Cypress (if added later)
test-results/
playwright-report/
cypress/screenshots/
cypress/videos/

# ── Env files ─────────────────────────────────────────────────────
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

