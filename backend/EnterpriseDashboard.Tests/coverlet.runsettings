<?xml version="1.0" encoding="utf-8" ?>
<RunSettings>
  <DataCollectionRunSettings>
    <DataCollectors>
      <DataCollector friendlyName="XPlat Code Coverage">
        <Configuration>
          <Format>cobertura</Format>
          <!-- Exclude startup bootstrapping and seeding — these require integration tests -->
          <ExcludeByFile>**/Program.cs,**/Data/SeedData.cs</ExcludeByFile>
          <!-- Exclude unused ApiResponse wrappers that no controller returns -->
          <ExcludeByAttribute>ExcludeFromCodeCoverage</ExcludeByAttribute>
        </Configuration>
      </DataCollector>
    </DataCollectors>
  </DataCollectionRunSettings>
</RunSettings>
